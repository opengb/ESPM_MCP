# Energy Star Portfolio Manager Credentials
# Your ESPM username (same as your Portfolio Manager login)
ESPM_USERNAME=your_username_here

# Your ESPM password (same as your Portfolio Manager login)
ESPM_PASSWORD=your_password_here

# API Environment - use "test" to try it out, "live" for your real portfolio
# NOTE: "live" requires EPA API approval (see README for instructions)
ESPM_ENV=test

# Optional: path to a read-only CSV with multiple ESPM accounts.
# Columns: username,password,env. Defaults to ./accounts.csv if unset.
# See accounts.csv.example for the format.
# ESPM_ACCOUNTS_CSV=./accounts.csv
