# Optional: path to the read-only CSV of ESPM accounts.
# Columns: username,password,env. Defaults to ./accounts.csv if unset.
# See accounts.csv.example for the format.
# ESPM_ACCOUNTS_CSV=./accounts.csv

# Alternative for read-only filesystems (e.g. PaaS): supply the CSV content
# directly as an env var. Takes precedence over ESPM_ACCOUNTS_CSV / accounts.csv.
# Use literal newlines or \n escape sequences between rows.
# ESPM_ACCOUNTS_CSV_DATA="username,password,env\nalice@example.com,pass1,test\nbob@example.com,pass2,live"

# Optional: HTTP server config (only used by `npm run start:http`).
# Defaults: port 3000, host 127.0.0.1.
# MCP_HTTP_PORT=3000
# MCP_HTTP_HOST=127.0.0.1

# Optional: require HTTP Basic auth on the /mcp endpoint.
# Both must be set together; leave both unset to disable auth (default).
# Cannot be combined with the MCP_HTTP_OAUTH_* options below.
# MCP_HTTP_BASIC_AUTH_USER=alice
# MCP_HTTP_BASIC_AUTH_PASS=change-me

# Optional: require OAuth 2.0 Bearer tokens on the /mcp endpoint, verified
# locally as JWTs against the issuer's JWKS. All four settings below must be
# set together. Cannot be combined with the MCP_HTTP_BASIC_AUTH_* options.
# MCP_HTTP_OAUTH_ISSUER accepts a comma-separated list if the IdP emits more
# than one (e.g. Google emits both forms of its issuer URL).
# MCP_HTTP_PUBLIC_URL is the server's public HTTPS base URL (no trailing slash);
# it is used to serve /.well-known/oauth-protected-resource so that MCP clients
# can discover the authorization server automatically.
# MCP_HTTP_PUBLIC_URL=https://your-server.com
# MCP_HTTP_OAUTH_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
# MCP_HTTP_OAUTH_ISSUER=https://accounts.google.com,accounts.google.com
# MCP_HTTP_OAUTH_AUDIENCE=1234567890-abc.apps.googleusercontent.com
# Optional: require a specific scope on the token (ignored if the token type
# has no `scope` claim — e.g. Google ID tokens).
# MCP_HTTP_OAUTH_REQUIRED_SCOPE=espm:read
